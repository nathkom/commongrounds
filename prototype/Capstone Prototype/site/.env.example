# Copy this file to .env.local and fill in real values for local development.
# For GitHub Pages deploys these are provided via repository Actions secrets
# (see .github/workflows/deploy.yml) and must NOT be committed.

# Mapbox GL access token (used by the neighborhoods map)
VITE_MAPBOX_TOKEN=

# Supabase project URL and anon/public key
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
